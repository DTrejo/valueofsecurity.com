{
  "scripts": {
    "build:css": "tailwindcss -i ./src/styles.input.css -o ./styles.css --minify",
    "build": "npm run build:css && node scripts/build.mjs",
    "watch:app": "node --watch-path src/index.html --watch-path scripts/build.mjs scripts/build.mjs",
    "watch:css": "tailwindcss -i ./src/styles.input.css -o ./styles.css --watch",
    "watch": "concurrently \"npm run watch:app\" \"npm run watch:css\"",
    "start": "concurrently \"npm run watch\" \"serve .\""
  },
  "devDependencies": {
    "@tailwindcss/cli": "4.2.4",
    "cheerio": "1.2.0",
    "concurrently": "9.2.1",
    "htm": "3.1.1",
    "preact": "10.29.1",
    "preact-render-to-string": "6.6.7",
    "serve": "14.2.6",
    "tailwindcss": "4.2.4"
  }
}
