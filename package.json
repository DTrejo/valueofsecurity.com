{
  "scripts": {
    "build:css": "tailwindcss -i ./styles.input.css -o ./gh-pages/styles.css --minify",
    "build": "npm run build:css && node scripts/build.mjs",
    "demo": "node scripts/demo.mjs",
    "watch:app": "node --watch-path index.html --watch-path scripts/build.mjs scripts/build.mjs",
    "watch:css": "npm run build:css -- --watch",
    "watch": "concurrently \"npm run watch:app\" \"npm run watch:css\"",
    "serve": "serve gh-pages",
    "start": "concurrently \"npm run watch\" \"npm run serve\""
  },
  "devDependencies": {
    "@fortawesome/fontawesome-free": "7.2.0",
    "@tailwindcss/cli": "4.2.4",
    "cheerio": "1.2.0",
    "concurrently": "9.2.1",
    "daisyui": "5.5.19",
    "htm": "3.1.1",
    "preact": "10.29.1",
    "preact-render-to-string": "6.6.7",
    "serve": "14.2.6",
    "tailwindcss": "4.2.4"
  }
}
